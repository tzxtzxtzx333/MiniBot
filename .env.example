MINIBOT_MAP_PROVIDER=mcp
MINIBOT_AMAP_MCP_ENDPOINT=
MINIBOT_AMAP_MCP_API_KEY=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_NAME=MiniBot
FEISHU_BOT_MODE=websocket
FEISHU_WS_ENABLED=true

MINIBOT_AGENT_PROFILE=default
MINIBOT_MAX_TOOL_ROUNDS=3
MINIBOT_MAX_TOOL_CALLS_TOTAL=10
MINIBOT_MAX_RUNTIME_SECONDS=60
MINIBOT_MAX_SAME_TOOL_CALLS=2

# Optional Bearer Token for HTTP Approval API.  When empty, local-dev access
# is unrestricted (recommended only when binding to 127.0.0.1).  Set a
# non-empty value to require `Authorization: Bearer <token>` on approval
# endpoints.
MINIBOT_HTTP_AUTH_TOKEN=

# Legacy compatibility keys, prefer MINIBOT_MODEL_BASE_URL / MINIBOT_MODEL_API_KEY.
MINIBOT_BASE_URL=
MINIBOT_API_KEY=
