MINIBOT_VERIFIER_MODE=real
MINIBOT_VERIFIER_PROVIDER=deepseek
MINIBOT_VERIFIER_BASE_URL=https://api.deepseek.com
MINIBOT_VERIFIER_API_KEY=
MINIBOT_VERIFIER_MODEL_NAME=deepseek-chat

MINIBOT_WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
TAVILY_PROJECT=
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5

MINIBOT_WEATHER_PROVIDER=real
MINIBOT_WEATHER_API_KEY=
