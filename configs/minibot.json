{
    "app_name":  "MiniBot",
    "version":  "0.1.0",
    "workspace_dir":  ".minibot",
    "model_mode":  "fake",
    "chat_turn_limit":  20,
    "context_token_budget":  1200,
    "archive_token_budget":  900,
    "max_tool_rounds":  3,
    "max_tool_calls_total":  10,
    "max_runtime_seconds":  60,
    "max_same_tool_calls":  2,
    "agent_profiles":  {
                           "test":  {
                                        "max_tool_rounds":  2,
                                        "max_tool_calls_total":  6,
                                        "max_runtime_seconds":  30,
                                        "max_same_tool_calls":  2
                                    },
                           "default":  {
                                           "max_tool_rounds":  3,
                                           "max_tool_calls_total":  10,
                                           "max_runtime_seconds":  60,
                                           "max_same_tool_calls":  2
                                       },
                           "real-agent":  {
                                              "max_tool_rounds":  5,
                                              "max_tool_calls_total":  15,
                                              "max_runtime_seconds":  90,
                                              "max_same_tool_calls":  3
                                          },
                           "long-task":  {
                                             "max_tool_rounds":  8,
                                             "max_tool_calls_total":  24,
                                             "max_runtime_seconds":  180,
                                             "max_same_tool_calls":  3
                                         }
                       },
    "history_retrieval":  {
                              "enabled":  true,
                              "mode":  "relevance",
                              "top_k":  5,
                              "max_chars":  2000
                          },
    "memory":  {
                   "auto_compact_enabled":  true,
                   "history_turn_compact_threshold":  20,
                   "history_compact_keep_recent":  6
               },
    "evidence":  {
                     "enabled":  true,
                     "tool_output_min_chars":  1500,
                     "summary_max_chars":  800,
                     "key_points_max":  5
                 },
    "http":  {
                 "host":  "127.0.0.1",
                 "port":  8000
             }
}
